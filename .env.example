# Database
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourApp

# JWT Tokens
TOKEN_SECRET_KEY=your_access_token_secret_key
REFRESH_TOKEN_SECRET_KEY=your_refresh_token_secret_key

# Redis
REDIS_UPSTASH_URL=redis://default:password@host:port

# CORS
CORS_ORIGIN=https://your-actual-vercel-domain.vercel.app

# Server
PORT=5000
NODE_ENV=production

# Vercel automatically provides these:
# VERCEL_URL=your-app.vercel.app (auto-generated)
# VERCEL_ENV=production