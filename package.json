{
  "name": "casri-management-system",
  "version": "1.0.0",
  "description": "CASRI Electronic Management System - Full Stack Application",
  "main": "BACKEND/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon BACKEND/index.js",
    "dev:frontend": "npm run dev --prefix FRONTEND1",
    "build": "npm run build:frontend",
    "build:frontend": "npm run build --prefix FRONTEND1",
    "start": "node BACKEND/index.js",
    "vercel-build": "npm run build:frontend",
    "install:all": "npm install --prefix FRONTEND1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.3",
    "multer": "^2.0.2",
    "path": "^0.12.7",
    "redis": "^5.0.1",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "@tailwindcss/postcss": "^4.1.7",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "keywords": ["fullstack", "inventory", "management", "react", "nodejs"],
  "author": "",
  "license": "ISC"
}