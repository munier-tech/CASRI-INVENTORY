{
  "name": "casri-management-system",
  "version": "1.0.0",
  "description": "CASRI Electronic Management System - Frontend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --prefix FRONTEND1",
    "dev:backend": "npm run dev --prefix BACKEND",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm run build --prefix FRONTEND1",
    "build:backend": "npm run build --prefix BACKEND",
    "build:all": "npm run build:backend && npm run build",
    "install:all": "npm install --prefix FRONTEND1 && npm install --prefix BACKEND",
    "start": "npm run start --prefix BACKEND",
    "vercel-build": "npm run build:all"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "frontend",
    "react",
    "inventory",
    "management"
  ],
  "author": "",
  "license": "ISC"
}
