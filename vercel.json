{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node@2.0.0" },
    { "src": "FRONTEND1/package.json", "use": "@vercel/static-build@1.0.0", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}